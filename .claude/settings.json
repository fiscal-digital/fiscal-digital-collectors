{
  "env": {
    "AWS_REGION": "us-east-1",
    "MSYS_NO_PATHCONV": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-legal-citation.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-legal-citation.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
